<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="021-add-fixed-asset-duration" author="librelog">
        <comment>Add duration and content_type fields to fixed_assets for songs, interviews, and other timed content</comment>
        
        <addColumn tableName="fixed_assets">
            <column name="duration_seconds" type="INTEGER">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        
        <addColumn tableName="fixed_assets">
            <column name="content_type" type="VARCHAR(50)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>

