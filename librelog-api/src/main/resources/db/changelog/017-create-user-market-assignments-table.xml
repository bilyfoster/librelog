<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
		http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

	<changeSet id="017-create-user-market-assignments-table" author="librelog">
		<comment>Create user_market_assignments table for Phase 2 market-level permission inheritance</comment>
		
		<createTable tableName="user_market_assignments">
			<column name="id" type="UUID">
				<constraints primaryKey="true" nullable="false"/>
			</column>
			<column name="user_id" type="UUID">
				<constraints nullable="false"/>
			</column>
			<column name="market_id" type="UUID">
				<constraints nullable="false"/>
			</column>
			<column name="permission_level" type="VARCHAR(50)">
				<constraints nullable="false"/>
			</column>
			<column name="custom_permissions" type="JSONB"/>
			<column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
				<constraints nullable="false"/>
			</column>
			<column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>
		</createTable>
		
		<addForeignKeyConstraint
			baseTableName="user_market_assignments"
			baseColumnNames="user_id"
			constraintName="fk_user_market_assignments_user"
			referencedTableName="users"
			referencedColumnNames="id"
			onDelete="CASCADE"/>
		
		<addForeignKeyConstraint
			baseTableName="user_market_assignments"
			baseColumnNames="market_id"
			constraintName="fk_user_market_assignments_market"
			referencedTableName="markets"
			referencedColumnNames="id"
			onDelete="CASCADE"/>
		
		<!-- Unique constraint to prevent duplicate assignments -->
		<addUniqueConstraint
			tableName="user_market_assignments"
			columnNames="user_id, market_id"
			constraintName="uk_user_market_assignments_user_market"/>
		
		<createIndex indexName="idx_user_market_assignments_user_id" tableName="user_market_assignments">
			<column name="user_id"/>
		</createIndex>
		
		<createIndex indexName="idx_user_market_assignments_market_id" tableName="user_market_assignments">
			<column name="market_id"/>
		</createIndex>
		
		<createIndex indexName="idx_user_market_assignments_permission_level" tableName="user_market_assignments">
			<column name="permission_level"/>
		</createIndex>
	</changeSet>

</databaseChangeLog>

