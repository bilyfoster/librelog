<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
		http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

	<changeSet id="006-add-station-type-column" author="librelog">
		<comment>Add station_type column to stations table</comment>
		
		<addColumn tableName="stations">
			<column name="station_type" type="VARCHAR(50)">
				<constraints nullable="false"/>
			</column>
		</addColumn>

		<!-- Set default value for existing records -->
		<update tableName="stations">
			<column name="station_type" value="FM"/>
		</update>

		<createIndex indexName="idx_stations_station_type" tableName="stations">
			<column name="station_type"/>
		</createIndex>

	</changeSet>

</databaseChangeLog>

