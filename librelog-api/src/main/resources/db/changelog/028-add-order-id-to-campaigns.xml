<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Add order_id to campaigns table to link orders to campaigns -->
    <changeSet id="028-add-order-id-to-campaigns" author="librelog">
        <addColumn tableName="campaigns">
            <column name="order_id" type="UUID"/>
        </addColumn>
        <addForeignKeyConstraint
                baseTableName="campaigns"
                baseColumnNames="order_id"
                constraintName="fk_campaigns_order"
                referencedTableName="orders"
                referencedColumnNames="id"
                onDelete="SET NULL"/>
        <createIndex indexName="idx_campaigns_order_id" tableName="campaigns">
            <column name="order_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
