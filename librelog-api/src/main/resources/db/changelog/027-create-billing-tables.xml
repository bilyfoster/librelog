<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Invoices table -->
    <changeSet id="027-create-invoices-table" author="librelog">
        <createTable tableName="invoices">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="invoice_number" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="campaign_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="advertiser_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="invoice_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="due_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="subtotal" type="NUMERIC(19,2)"/>
            <column name="tax_rate" type="NUMERIC(5,4)"/>
            <column name="tax_amount" type="NUMERIC(19,2)"/>
            <column name="total_amount" type="NUMERIC(19,2)"/>
            <column name="amount_paid" type="NUMERIC(19,2)"/>
            <column name="balance_due" type="NUMERIC(19,2)"/>
            <column name="notes" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint
                baseTableName="invoices"
                baseColumnNames="campaign_id"
                constraintName="fk_invoices_campaign"
                referencedTableName="campaigns"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
        <addForeignKeyConstraint
                baseTableName="invoices"
                baseColumnNames="advertiser_id"
                constraintName="fk_invoices_advertiser"
                referencedTableName="advertisers"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
        <createIndex indexName="idx_invoices_campaign_id" tableName="invoices">
            <column name="campaign_id"/>
        </createIndex>
        <createIndex indexName="idx_invoices_advertiser_id" tableName="invoices">
            <column name="advertiser_id"/>
        </createIndex>
        <createIndex indexName="idx_invoices_status" tableName="invoices">
            <column name="status"/>
        </createIndex>
        <createIndex indexName="idx_invoices_due_date" tableName="invoices">
            <column name="due_date"/>
        </createIndex>
    </changeSet>

    <!-- Invoice lines table -->
    <changeSet id="027-create-invoice-lines-table" author="librelog">
        <createTable tableName="invoice_lines">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="invoice_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="spot_date" type="DATE"/>
            <column name="daypart" type="VARCHAR(50)"/>
            <column name="spot_length_seconds" type="INTEGER"/>
            <column name="quantity" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="unit_price" type="NUMERIC(19,2)"/>
            <column name="line_total" type="NUMERIC(19,2)"/>
            <column name="spot_id" type="UUID"/>
        </createTable>
        <addForeignKeyConstraint
                baseTableName="invoice_lines"
                baseColumnNames="invoice_id"
                constraintName="fk_invoice_lines_invoice"
                referencedTableName="invoices"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
        <createIndex indexName="idx_invoice_lines_invoice_id" tableName="invoice_lines">
            <column name="invoice_id"/>
        </createIndex>
    </changeSet>

    <!-- Payments table -->
    <changeSet id="027-create-payments-table" author="librelog">
        <createTable tableName="payments">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="invoice_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="NUMERIC(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="payment_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="payment_method" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="reference_number" type="VARCHAR(255)"/>
            <column name="notes" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
                baseTableName="payments"
                baseColumnNames="invoice_id"
                constraintName="fk_payments_invoice"
                referencedTableName="invoices"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
        <createIndex indexName="idx_payments_invoice_id" tableName="payments">
            <column name="invoice_id"/>
        </createIndex>
        <createIndex indexName="idx_payments_date" tableName="payments">
            <column name="payment_date"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
