<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="029-add-advertiser-to-orders" author="librelog">
        <comment>Add advertiser_id foreign key to orders table</comment>
        
        <!-- Add advertiser_id column -->
        <addColumn tableName="orders">
            <column name="advertiser_id" type="UUID">
                <constraints nullable="true" foreignKeyName="fk_order_advertiser" 
                             references="advertisers(id)"/>
            </column>
        </addColumn>
        
        <!-- Create index for faster lookups -->
        <createIndex indexName="idx_orders_advertiser_id" tableName="orders">
            <column name="advertiser_id"/>
        </createIndex>
        
    </changeSet>

</databaseChangeLog>
