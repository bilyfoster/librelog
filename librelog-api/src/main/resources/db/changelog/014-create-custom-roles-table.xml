<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
		http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

	<changeSet id="014-create-custom-roles-table" author="librelog">
		<comment>Create custom_roles table for user-defined roles with granular permissions</comment>
		
		<createTable tableName="custom_roles">
			<column name="id" type="UUID">
				<constraints primaryKey="true" nullable="false"/>
			</column>
			<column name="name" type="VARCHAR(255)">
				<constraints nullable="false" unique="true"/>
			</column>
			<column name="description" type="TEXT"/>
			<column name="permissions" type="JSONB">
				<constraints nullable="false"/>
			</column>
			<column name="created_by_user_id" type="UUID">
				<constraints nullable="false"/>
			</column>
			<column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
				<constraints nullable="false"/>
			</column>
			<column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>
		</createTable>
		
		<addForeignKeyConstraint
			baseTableName="custom_roles"
			baseColumnNames="created_by_user_id"
			constraintName="fk_custom_roles_created_by_user"
			referencedTableName="users"
			referencedColumnNames="id"
			onDelete="RESTRICT"/>
		
		<createIndex indexName="idx_custom_roles_name" tableName="custom_roles">
			<column name="name"/>
		</createIndex>
		
		<createIndex indexName="idx_custom_roles_created_by_user_id" tableName="custom_roles">
			<column name="created_by_user_id"/>
		</createIndex>
	</changeSet>

</databaseChangeLog>

