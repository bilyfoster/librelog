<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
		http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

	<changeSet id="006-enhance-break-structures" author="librelog">
		<comment>Enhance break_structures table with avail_type, timing_type, and transition_code columns</comment>
		
		<!-- Add avail_type_id column (nullable, will be set to FK later if needed) -->
		<addColumn tableName="break_structures">
			<column name="avail_type_id" type="UUID"/>
		</addColumn>
		
		<!-- Add timing_type column -->
		<addColumn tableName="break_structures">
			<column name="timing_type" type="VARCHAR(50)"/>
		</addColumn>
		
		<!-- Add transition_code column -->
		<addColumn tableName="break_structures">
			<column name="transition_code" type="VARCHAR(50)"/>
		</addColumn>
		
		<!-- Create index on avail_type_id for performance -->
		<createIndex indexName="idx_break_structures_avail_type_id" tableName="break_structures">
			<column name="avail_type_id"/>
		</createIndex>
		
		<!-- Create index on timing_type for filtering -->
		<createIndex indexName="idx_break_structures_timing_type" tableName="break_structures">
			<column name="timing_type"/>
		</createIndex>
	</changeSet>

</databaseChangeLog>

