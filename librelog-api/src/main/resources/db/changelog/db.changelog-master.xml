<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
		http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

	<changeSet id="001-create-users-table" author="librelog">
		<createTable tableName="users">
			<column name="id" type="UUID">
				<constraints primaryKey="true" nullable="false"/>
			</column>
			<column name="email" type="VARCHAR(255)">
				<constraints nullable="false" unique="true"/>
			</column>
			<column name="password" type="VARCHAR(255)">
				<constraints nullable="false"/>
			</column>
			<column name="status" type="VARCHAR(50)">
				<constraints nullable="false"/>
			</column>
			<column name="role" type="VARCHAR(50)">
				<constraints nullable="false"/>
			</column>
			<column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
				<constraints nullable="false"/>
			</column>
			<column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>
		</createTable>
	</changeSet>

	<changeSet id="002-create-stations-table" author="librelog">
		<createTable tableName="stations">
			<column name="id" type="UUID">
				<constraints primaryKey="true" nullable="false"/>
			</column>
			<column name="call_sign" type="VARCHAR(255)">
				<constraints nullable="false" unique="true"/>
			</column>
			<column name="name" type="VARCHAR(255)">
				<constraints nullable="false"/>
			</column>
			<column name="frequency" type="VARCHAR(50)"/>
			<column name="market" type="VARCHAR(255)"/>
			<column name="created_at" type="TIMESTAMP">
				<constraints nullable="false"/>
			</column>
			<column name="updated_at" type="TIMESTAMP"/>
		</createTable>
		<createIndex indexName="idx_stations_call_sign" tableName="stations">
			<column name="call_sign"/>
		</createIndex>
	</changeSet>

	<changeSet id="002-create-channels-table" author="librelog">
		<createTable tableName="channels">
			<column name="id" type="UUID">
				<constraints primaryKey="true" nullable="false"/>
			</column>
			<column name="station_id" type="UUID">
				<constraints nullable="false"/>
			</column>
			<column name="name" type="VARCHAR(255)">
				<constraints nullable="false"/>
			</column>
			<column name="channel_number" type="INTEGER"/>
			<column name="created_at" type="TIMESTAMP">
				<constraints nullable="false"/>
			</column>
			<column name="updated_at" type="TIMESTAMP"/>
		</createTable>
		<addForeignKeyConstraint
			baseTableName="channels"
			baseColumnNames="station_id"
			constraintName="fk_channels_station"
			referencedTableName="stations"
			referencedColumnNames="id"
			onDelete="CASCADE"/>
		<createIndex indexName="idx_channels_station_id" tableName="channels">
			<column name="station_id"/>
		</createIndex>
	</changeSet>

