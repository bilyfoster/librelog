	<changeSet id="003-create-admin-user" author="librelog">
		<comment>Create initial admin user (admin@librelog.com/admin123)</comment>
		<sql>
			-- Password: admin123 (bcrypt hash)
			INSERT INTO users (id, email, password, status, role, created_at, updated_at)
			VALUES (
				gen_random_uuid(),
				'admin@librelog.com',
				'$2a$10$N9qo8uLOickgx2ZMRZoMyeIjZAgcfl7p92ldGxad68LJZdL17lhWy',
