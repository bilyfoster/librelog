<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002-rebuild-stations" author="rebuild">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="stations"/>
            </not>
        </preConditions>
        <comment>Create stations table - Phase 1: Foundation</comment>

        <!-- Create stations table -->
        <createTable tableName="stations">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="call_letters" type="VARCHAR(10)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="frequency" type="VARCHAR(20)">
                <constraints nullable="true"/>
            </column>
            <column name="market" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="format" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
            <column name="ownership" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="contacts" type="JSONB">
                <constraints nullable="true"/>
            </column>
            <column name="rates" type="JSONB">
                <constraints nullable="true"/>
            </column>
            <column name="inventory_class" type="VARCHAR(50)">
                <constraints nullable="true"/>
            </column>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Create indexes -->
        <createIndex tableName="stations" indexName="ix_stations_id">
            <column name="id"/>
        </createIndex>

        <createIndex tableName="stations" indexName="ix_stations_call_letters" unique="true">
            <column name="call_letters"/>
        </createIndex>

        <createIndex tableName="stations" indexName="ix_stations_frequency">
            <column name="frequency"/>
        </createIndex>

        <createIndex tableName="stations" indexName="ix_stations_market">
            <column name="market"/>
        </createIndex>

        <createIndex tableName="stations" indexName="ix_stations_inventory_class">
            <column name="inventory_class"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>

