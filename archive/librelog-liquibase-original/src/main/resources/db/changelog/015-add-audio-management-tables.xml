<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="015-add-audio-management-tables" author="migration">
        <comment>Add audio management tables: audio_cuts, audio_versions, live_reads, political_records, audio_deliveries, audio_qc_results, and extend copy and rotation_rules tables</comment>

        <!-- Create audio_cuts table -->
        <createTable tableName="audio_cuts">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="copy_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="cut_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="cut_name" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="audio_file_path" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="audio_file_url" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="file_checksum" type="VARCHAR(64)">
                <constraints nullable="true"/>
            </column>
            <column name="version" type="INTEGER" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="rotation_weight" type="DOUBLE PRECISION" defaultValueNumeric="1.0">
                <constraints nullable="true"/>
            </column>
            <column name="daypart_restrictions" type="JSONB">
                <constraints nullable="true"/>
            </column>
            <column name="program_associations" type="JSONB">
                <constraints nullable="true"/>
            </column>
            <column name="expires_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="true"/>
            </column>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="true"/>
            </column>
            <column name="qc_results" type="JSONB">
                <constraints nullable="true"/>
            </column>
            <column name="notes" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="tags" type="JSONB">
                <constraints nullable="true"/>
            </column>
            <column name="created_by" type="UUID">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="true"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="audio_cuts"
            baseColumnNames="copy_id"
            constraintName="fk_audio_cuts_copy_id"
            referencedTableName="copy"
            referencedColumnNames="id"/>
        <addForeignKeyConstraint
            baseTableName="audio_cuts"
            baseColumnNames="created_by"
            constraintName="fk_audio_cuts_created_by"
            referencedTableName="users"
            referencedColumnNames="id"/>

        <sql>
            <![CDATA[
            ALTER TABLE audio_cuts ADD CONSTRAINT check_rotation_weight_positive CHECK (rotation_weight >= 0);
            ]]>
        </sql>

        <createIndex tableName="audio_cuts" indexName="ix_audio_cuts_copy_id">
            <column name="copy_id"/>
        </createIndex>
        <createIndex tableName="audio_cuts" indexName="ix_audio_cuts_cut_id">
            <column name="cut_id"/>
        </createIndex>
        <createIndex tableName="audio_cuts" indexName="ix_audio_cuts_expires_at">
            <column name="expires_at"/>
        </createIndex>
        <createIndex tableName="audio_cuts" indexName="ix_audio_cuts_active">
            <column name="active"/>
        </createIndex>

        <!-- Create audio_versions table -->
        <createTable tableName="audio_versions">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="cut_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="version_number" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="audio_file_path" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="audio_file_url" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="file_checksum" type="VARCHAR(64)">
                <constraints nullable="true"/>
            </column>
            <column name="version_notes" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="changed_by" type="UUID">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="audio_versions"
            baseColumnNames="cut_id"
            constraintName="fk_audio_versions_cut_id"
            referencedTableName="audio_cuts"
            referencedColumnNames="id"/>
        <addForeignKeyConstraint
            baseTableName="audio_versions"
            baseColumnNames="changed_by"
            constraintName="fk_audio_versions_changed_by"
            referencedTableName="users"
            referencedColumnNames="id"/>

        <createIndex tableName="audio_versions" indexName="ix_audio_versions_cut_id">
            <column name="cut_id"/>
        </createIndex>

