        <addColumn tableName="copy">
            <column name="cut_count" type="INTEGER" defaultValueNumeric="0"/>
            <column name="rotation_mode" type="VARCHAR(50)"/>
            <column name="political_flag" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="live_read_enabled" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="copy_instructions" type="TEXT"/>
            <column name="instruction_attachments" type="TEXT"/>
        </addColumn>

        <createIndex tableName="copy" indexName="ix_copy_political_flag">
            <column name="political_flag"/>
        </createIndex>
        <createIndex tableName="copy" indexName="ix_copy_live_read_enabled">
