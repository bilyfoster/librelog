        <!-- Create audio_deliveries table -->
        <createTable tableName="audio_deliveries">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="cut_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="copy_id" type="UUID">
                <constraints nullable="true"/>
            </column>
            <column name="delivery_method" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="target_server" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="target_path" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="pending">
                <constraints nullable="true"/>
            </column>
            <column name="retry_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="true"/>
            </column>
            <column name="max_retries" type="INTEGER" defaultValueNumeric="3">
                <constraints nullable="true"/>
            </column>
            <column name="source_checksum" type="VARCHAR(64)">
                <constraints nullable="true"/>
            </column>
            <column name="delivered_checksum" type="VARCHAR(64)">
                <constraints nullable="true"/>
            </column>
            <column name="checksum_verified" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="true"/>
            </column>
            <column name="delivery_started_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="true"/>
            </column>
            <column name="delivery_completed_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="true"/>
            </column>
            <column name="last_retry_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="true"/>
            </column>
            <column name="error_message" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="error_details" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="true"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="true"/>
            </column>
        </createTable>

