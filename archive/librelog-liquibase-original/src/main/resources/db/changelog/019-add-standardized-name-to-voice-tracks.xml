<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="019-add-standardized-name-to-voice-tracks" author="migration">
        <comment>Add standardized_name and recorded_date to voice_tracks and voice_track_slots</comment>

        <!-- Add standardized_name to voice_track_slots -->
        <addColumn tableName="voice_track_slots">
            <column name="standardized_name" type="VARCHAR(50)"/>
        </addColumn>

        <createIndex tableName="voice_track_slots" indexName="ix_voice_track_slots_standardized_name">
            <column name="standardized_name"/>
        </createIndex>

        <!-- Add standardized_name and recorded_date to voice_tracks -->
        <addColumn tableName="voice_tracks">
            <column name="standardized_name" type="VARCHAR(50)"/>
            <column name="recorded_date" type="TIMESTAMP WITH TIME ZONE"/>
        </addColumn>

        <createIndex tableName="voice_tracks" indexName="ix_voice_tracks_standardized_name">
            <column name="standardized_name"/>
        </createIndex>
        <createIndex tableName="voice_tracks" indexName="ix_voice_tracks_recorded_date">
            <column name="recorded_date"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>


