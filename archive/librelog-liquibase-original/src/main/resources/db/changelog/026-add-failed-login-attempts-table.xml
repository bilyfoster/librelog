<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="026-add-failed-login-attempts-table" author="migration">
        <comment>Add failed_login_attempts table for security tracking</comment>

        <!-- Create failed_login_attempts table -->
        <createTable tableName="failed_login_attempts">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="username" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="ip_address" type="VARCHAR(45)"/>
            <column name="user_agent" type="VARCHAR(255)"/>
            <column name="attempted_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="failed_login_attempts" indexName="ix_failed_login_attempts_id">
            <column name="id"/>
        </createIndex>
        <createIndex tableName="failed_login_attempts" indexName="ix_failed_login_attempts_username">
            <column name="username"/>
        </createIndex>
        <createIndex tableName="failed_login_attempts" indexName="idx_username_attempted_at">
            <column name="username"/>
            <column name="attempted_at"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>


