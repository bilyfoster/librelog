<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="008-add-digital-orders" author="migration">
        <comment>Add digital orders table</comment>

        <!-- Create enum types -->
        <sql>
            CREATE TYPE platform AS ENUM ('WEBSITE', 'PODCAST', 'STREAMING', 'SOCIAL_MEDIA');
            CREATE TYPE digitalorderstatus AS ENUM ('DRAFT', 'ACTIVE', 'COMPLETED', 'CANCELLED');
        </sql>

        <!-- Create digital_orders table -->
        <createTable tableName="digital_orders">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="platform" type="platform">
                <constraints nullable="false"/>
            </column>
            <column name="impression_target" type="INTEGER">
                <constraints nullable="true"/>
            </column>
            <column name="cpm" type="NUMERIC(10,2)">
                <constraints nullable="true"/>
            </column>
            <column name="cpc" type="NUMERIC(10,2)">
                <constraints nullable="true"/>
            </column>
            <column name="flat_rate" type="NUMERIC(10,2)">
                <constraints nullable="true"/>
            </column>
            <column name="creative_assets" type="JSONB">
                <constraints nullable="true"/>
            </column>
            <column name="delivered_impressions" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="true"/>
            </column>
            <column name="status" type="digitalorderstatus" defaultValue="DRAFT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="true"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="digital_orders"
            baseColumnNames="order_id"
            constraintName="fk_digital_orders_order_id"
            referencedTableName="orders"
            referencedColumnNames="id"/>

        <createIndex tableName="digital_orders" indexName="ix_digital_orders_id">
            <column name="id"/>
        </createIndex>
        <createIndex tableName="digital_orders" indexName="ix_digital_orders_order_id">
            <column name="order_id"/>
        </createIndex>
        <createIndex tableName="digital_orders" indexName="ix_digital_orders_status">
            <column name="status"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>


