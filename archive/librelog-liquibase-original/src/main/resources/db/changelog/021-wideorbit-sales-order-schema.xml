<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="021-wideorbit-sales-order-schema" author="migration">
        <comment>Add WideOrbit sales order schema enhancements: order_lines, order_attachments, order_revisions, order_workflow_states, and extend orders, copy, invoices, political_records tables</comment>

        <!-- Create enum types (if not exist) -->
        <sql>
            DO $$ BEGIN
                CREATE TYPE ordertype AS ENUM ('LOCAL', 'NATIONAL', 'NETWORK', 'DIGITAL', 'NTR');
            EXCEPTION WHEN duplicate_object THEN null; END $$;
            DO $$ BEGIN
                CREATE TYPE billingcycle AS ENUM ('WEEKLY', 'MONTHLY', 'ONE_SHOT', 'BIWEEKLY', 'QUARTERLY');
            EXCEPTION WHEN duplicate_object THEN null; END $$;
            DO $$ BEGIN
                CREATE TYPE invoicetype AS ENUM ('STANDARD', 'COOP', 'POLITICAL');
            EXCEPTION WHEN duplicate_object THEN null; END $$;
            DO $$ BEGIN
                CREATE TYPE politicalclass AS ENUM ('FEDERAL', 'STATE', 'LOCAL', 'ISSUE');
            EXCEPTION WHEN duplicate_object THEN null; END $$;
            DO $$ BEGIN
                CREATE TYPE revenuetype AS ENUM ('SPOT', 'DIGITAL', 'TRADE', 'PROMOTION', 'NTR');
            EXCEPTION WHEN duplicate_object THEN null; END $$;
            DO $$ BEGIN
                CREATE TYPE selloutclass AS ENUM ('ROS', 'FIXED_POSITION', 'BONUS', 'GUARANTEED');
            EXCEPTION WHEN duplicate_object THEN null; END $$;
            DO $$ BEGIN
                CREATE TYPE attachmenttype AS ENUM ('CONTRACT', 'AUDIO', 'SCRIPT', 'CREATIVE', 'LEGAL', 'IO', 'EMAIL', 'OTHER');
            EXCEPTION WHEN duplicate_object THEN null; END $$;
            DO $$ BEGIN
                CREATE TYPE revisionreasoncode AS ENUM ('PRICE_CHANGE', 'EXTENSION', 'CANCELLATION', 'LINE_ADDED', 'LINE_REMOVED', 'COPY_CHANGE', 'DATE_CHANGE', 'OTHER');
            EXCEPTION WHEN duplicate_object THEN null; END $$;
            DO $$ BEGIN
                CREATE TYPE workflowstate AS ENUM ('DRAFT', 'PENDING_APPROVAL', 'APPROVED', 'TRAFFIC_READY', 'BILLING_READY', 'LOCKED', 'CANCELLED');
            EXCEPTION WHEN duplicate_object THEN null; END $$;
            DO $$ BEGIN
                CREATE TYPE copytype AS ENUM ('NEW', 'TAG_UPDATE', 'RENEWAL', 'SEASONAL');
            EXCEPTION WHEN duplicate_object THEN null; END $$;
            DO $$ BEGIN
                CREATE TYPE revenuebucket AS ENUM ('SPOT', 'DIGITAL', 'TRADE', 'PROMOTIONS');
            EXCEPTION WHEN duplicate_object THEN null; END $$;
        </sql>

        <!-- Enhance orders table -->
        <addColumn tableName="orders">
            <column name="order_name" type="VARCHAR(255)"/>
            <column name="sales_team" type="VARCHAR(100)"/>
            <column name="sales_office" type="VARCHAR(100)"/>
            <column name="sales_region" type="VARCHAR(100)"/>
            <column name="stations" type="JSONB"/>
            <column name="cluster" type="VARCHAR(100)"/>
            <column name="order_type" type="ordertype"/>
            <column name="gross_amount" type="NUMERIC(12,2)" defaultValueNumeric="0"/>
            <column name="net_amount" type="NUMERIC(12,2)" defaultValueNumeric="0"/>
            <column name="agency_commission_percent" type="NUMERIC(5,2)"/>
            <column name="agency_commission_amount" type="NUMERIC(12,2)"/>
            <column name="agency_discount" type="NUMERIC(12,2)"/>
            <column name="cash_discount" type="NUMERIC(12,2)"/>
            <column name="trade_barter" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="trade_value" type="NUMERIC(12,2)"/>
            <column name="taxable" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="billing_cycle" type="billingcycle"/>
            <column name="invoice_type" type="invoicetype"/>
            <column name="coop_sponsor" type="VARCHAR(255)"/>
            <column name="coop_percent" type="NUMERIC(5,2)"/>
            <column name="client_po_number" type="VARCHAR(100)"/>
            <column name="billing_address" type="TEXT"/>
            <column name="billing_contact" type="VARCHAR(255)"/>
            <column name="billing_contact_email" type="VARCHAR(255)"/>
            <column name="billing_contact_phone" type="VARCHAR(50)"/>
            <column name="political_class" type="politicalclass"/>
            <column name="political_window_flag" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="contract_reference" type="VARCHAR(100)"/>
            <column name="insertion_order_number" type="VARCHAR(100)"/>
            <column name="regulatory_notes" type="TEXT"/>
            <column name="fcc_id" type="VARCHAR(100)"/>
            <column name="required_disclaimers" type="TEXT"/>
            <column name="traffic_ready" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="billing_ready" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="locked" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="revision_number" type="INTEGER" defaultValueNumeric="1"/>
            <column name="created_by" type="UUID"/>
        </addColumn>

        <addForeignKeyConstraint
            baseTableName="orders"
            baseColumnNames="created_by"
            constraintName="fk_orders_created_by"
            referencedTableName="users"
            referencedColumnNames="id"/>

        <createIndex tableName="orders" indexName="ix_orders_order_name">
            <column name="order_name"/>
        </createIndex>
        <createIndex tableName="orders" indexName="ix_orders_order_type">
