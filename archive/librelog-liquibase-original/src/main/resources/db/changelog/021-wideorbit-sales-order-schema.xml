        <!-- Create order_attachments table -->
        <createTable tableName="order_attachments">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_id" type="UUID"/>
            <column name="order_line_id" type="UUID"/>
            <column name="copy_id" type="UUID"/>
            <column name="file_path" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="file_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="mime_type" type="VARCHAR(100)"/>
            <column name="file_size" type="BIGINT"/>
            <column name="attachment_type" type="attachmenttype">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="notes" type="TEXT"/>
            <column name="uploaded_by" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="uploaded_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

