        <!-- Create order_lines table -->
        <createTable tableName="order_lines">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="line_number" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="start_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="end_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="station" type="VARCHAR(100)"/>
            <column name="product" type="VARCHAR(255)"/>
            <column name="revenue_type" type="revenuetype"/>
            <column name="length" type="INTEGER"/>
            <column name="daypart" type="VARCHAR(50)"/>
            <column name="days_of_week" type="VARCHAR(7)"/>
            <column name="rate" type="NUMERIC(12,2)"/>
            <column name="rate_type" type="VARCHAR(50)"/>
            <column name="sellout_class" type="selloutclass"/>
            <column name="priority_code" type="VARCHAR(50)"/>
            <column name="spot_frequency" type="INTEGER"/>
            <column name="estimated_impressions" type="INTEGER"/>
            <column name="cpm" type="NUMERIC(10,2)"/>
            <column name="cpp" type="NUMERIC(10,2)"/>
            <column name="makegood_eligible" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="guaranteed_position" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="preemptible" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="inventory_class" type="VARCHAR(100)"/>
            <column name="product_code" type="VARCHAR(100)"/>
            <column name="deal_points" type="TEXT"/>
            <column name="notes" type="TEXT"/>
            <column name="platform" type="VARCHAR(100)"/>
            <column name="impressions_booked" type="INTEGER"/>
            <column name="delivery_window" type="VARCHAR(100)"/>
            <column name="targeting_parameters" type="JSONB"/>
            <column name="companion_banners" type="JSONB"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="order_lines"
            baseColumnNames="order_id"
            constraintName="fk_order_lines_order_id"
            referencedTableName="orders"
