<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="023-add-station-support" author="migration">
        <comment>Add station support: user_stations association table and station_id columns to various tables</comment>

        <!-- Create user_stations association table -->
        <createTable tableName="user_stations">
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="station_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="user_stations" columnNames="user_id,station_id"/>
        <addForeignKeyConstraint
            baseTableName="user_stations"
            baseColumnNames="user_id"
            constraintName="fk_user_stations_user_id"
            referencedTableName="users"
            referencedColumnNames="id"
            onDelete="CASCADE"/>
        <addForeignKeyConstraint
            baseTableName="user_stations"
            baseColumnNames="station_id"
            constraintName="fk_user_stations_station_id"
            referencedTableName="stations"
            referencedColumnNames="id"
            onDelete="CASCADE"/>

        <createIndex tableName="user_stations" indexName="ix_user_stations_user_id">
            <column name="user_id"/>
        </createIndex>
        <createIndex tableName="user_stations" indexName="ix_user_stations_station_id">
            <column name="station_id"/>
        </createIndex>

        <!-- Add station_id to spots (NOT NULL) -->
        <addColumn tableName="spots">
            <column name="station_id" type="UUID"/>
        </addColumn>

        <sql>
            UPDATE spots SET station_id = (SELECT id FROM stations LIMIT 1) WHERE station_id IS NULL;
        </sql>

        <addNotNullConstraint tableName="spots" columnName="station_id" columnDataType="UUID"/>
        <addForeignKeyConstraint
            baseTableName="spots"
            baseColumnNames="station_id"
            constraintName="fk_spots_station_id"
            referencedTableName="stations"
            referencedColumnNames="id"/>
        <createIndex tableName="spots" indexName="ix_spots_station_id">
            <column name="station_id"/>
        </createIndex>

