        <createIndex tableName="daily_logs" indexName="ix_daily_logs_station_id">
            <column name="station_id"/>
        </createIndex>

        <!-- Add unique constraint on daily_logs (date, station_id) -->
        <addUniqueConstraint tableName="daily_logs" columnNames="date,station_id" constraintName="uq_daily_logs_date_station"/>

